# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_DB_URL=your-session-pooler-connection-uri
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# OpenClaw workspace (set automatically by `sudo dashboard bridge`)
OPENCLAW_WORKSPACE_ID=
OPENCLAW_AGENT_ID=

# Debug (optional)
NEXT_PUBLIC_AGENT_DEBUG_OVERLAY=false
OPENCLAW_AGENT_DATA_DEBUG=false
